generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String        @id @default(cuid())
  name               String
  email              String?       @unique
  phone              String?       @unique
  role               String        @default("USER")
  password           String?
  image              String?
  emailVerified      DateTime?
  dateOfBirth        DateTime?
  timeOfBirth        String?
  placeOfBirth       String?
  latitude           Float?
  longitude          Float?
  gender             String?
  maritalStatus      String?
  occupation         String?
  languagePreference String        @default("english")
  zodiacSign         String?
  reasonForJoining   String?
  profileComplete    Boolean       @default(false)
  subscriptionStatus String        @default("INACTIVE")
  subscriptionExpiry DateTime?
  subscriptionPrice  Int           @default(1499)
  chatSessions       ChatSession[]
  accounts           Account[]
  sessions           Session[]
  poojaBookings      PoojaBooking[]
  wallet             Wallet?
  transactions       Transaction[]
  orders             Order[]
  application        AstrologerApplication?
  
  // Astrologer Profile Fields
  astrologerRating     Float?    @default(5.0)
  astrologerExperience Int?      @default(0)
  astrologerPrice      Int?      @default(20)
  astrologerSpecialties String?
  astrologerLanguages   String?

  // Bank Details for Payout
  bankAccountHolder  String?
  bankAccountNumber  String?
  bankIfscCode       String?
  bankName           String?

  // Rating and Reporting System
  givenReviews       Review[] @relation("UserReviews")
  receivedReviews    Review[] @relation("AstrologerReviews")
  givenReports       Report[] @relation("UserReports")
  receivedReports    Report[] @relation("AstrologerReports")

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model AstrologerApplication {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  experienceYears Int
  specialties     String
  languages       String
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  paymentStatus   String   @default("UNPAID")  // UNPAID, PAID
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PoojaBooking {
  id          String   @id @default(cuid())
  userId      String
  poojaId     String
  poojaTitle  String
  price       Int
  status      String   @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id             String        @id @default(cuid())
  userId         String
  title          String        @default("New Chat")
  astrologerId   String?
  astrologerUserId String?     // ID of the ASTROLOGER user handling this session
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  lastHumanReplyAt DateTime?   // Tracks when astrologer last replied (for AI fallback)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       ChatMessage[]
}

model ChatMessage {
  id         String      @id @default(cuid())
  sessionId  String
  role       String      // "user" | "assistant"
  content    String
  senderRole String      @default("AI")  // "AI" | "ASTROLOGER" | "USER"
  createdAt  DateTime    @default(now())
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Review {
  id           String   @id @default(cuid())
  userId       String
  astrologerId String
  rating       Int      // 1 to 5
  feedback     String?
  createdAt    DateTime @default(now())
  
  user         User     @relation("UserReviews", fields: [userId], references: [id], onDelete: Cascade)
  astrologer   User     @relation("AstrologerReviews", fields: [astrologerId], references: [id], onDelete: Cascade)
}

model Report {
  id           String   @id @default(cuid())
  userId       String
  astrologerId String
  category     String   // e.g., "Misbehavior", "Spam", "Other"
  description  String
  status       String   @default("OPEN") // OPEN, RESOLVED, DISMISSED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  user         User     @relation("UserReports", fields: [userId], references: [id], onDelete: Cascade)
  astrologer   User     @relation("AstrologerReports", fields: [astrologerId], references: [id], onDelete: Cascade)
}

model Wallet {
  id               String   @id @default(cuid())
  astrologerId     String   @unique
  availableBalance Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [astrologerId], references: [id], onDelete: Cascade)
}

model Transaction {
  id            String   @id @default(cuid())
  userId        String?  // Can be null if paid by guest, though we assume auth users
  astrologerId  String
  amount        Int
  astrologerCut Int
  platformCut   Int
  type          String   // "CHAT_GURUDAKSHINA" or "POOJA"
  status        String   @default("COMPLETED")
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model PlatformSettings {
  id        String   @id @default("global")
  themeName String   @default("cosmic") // cosmic, emerald, ruby, ocean
  updatedAt DateTime @updatedAt
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  totalAmount   Float
  paymentStatus String      @default("PENDING") // PENDING, COMPLETED, FAILED
  shippingStatus String     @default("PROCESSING") // PROCESSING, SHIPPED, DELIVERED
  shippingAddress String?   
  paymentMethod String      @default("SIMULATED")
  utrNumber     String?     // For manual UPI payments
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  gemId     String   
  gemName   String
  quantity  Int      @default(1)
  price     Float    
}

model PaymentSettings {
  id            String   @id @default("global")
  activeMethod  String   @default("SIMULATED") // SIMULATED, MANUAL_UPI_QR, RAZORPAY
  upiId         String?  // e.g. merchant@paytm
  merchantName  String?  // e.g. Astro Solution
  razorpayKey   String?
  razorpaySecret String?
  updatedAt     DateTime @updatedAt
}
